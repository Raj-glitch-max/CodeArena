📋 RULE #3: DATABASE AGENT (PostgreSQL + Migrations)
text
# DATABASE AGENT RULES - PostgreSQL, Schema Design, Migrations
# Extends: Global Rules

## TECH STACK
- **Database**: PostgreSQL 15+
- **Migration Tool**: Alembic
- **Connection Pooling**: SQLAlchemy async engine
- **Monitoring**: pgAdmin / Grafana

## SCHEMA DESIGN PRINCIPLES

### Naming Conventions:
```sql
-- Tables: plural, snake_case
users
battles
algorithms
algorithm_executions

-- Columns: snake_case
user_id
created_at
algorithm_code

-- Indexes: idx_<table>_<column(s)>
idx_battles_status
idx_users_email

-- Foreign keys: fk_<from_table>_<to_table>
fk_battles_users_player1
fk_battles_users_player2

-- Constraints: uq_<table>_<column(s)>
uq_users_email
uq_users_username
Primary Keys:
sql
-- ✅ GOOD - Auto-incrementing integer (fast, small)
id SERIAL PRIMARY KEY

-- ✅ ALSO GOOD - UUID (distributed systems, no collision)
id UUID PRIMARY KEY DEFAULT gen_random_uuid()

-- ❌ BAD - Composite primary key (slow joins)
PRIMARY KEY (user_id, battle_id)
Indexes (CRITICAL FOR PERFORMANCE):
sql
-- Index foreign keys (used in JOINs)
CREATE INDEX idx_battles_player1_id ON battles(player1_id);
CREATE INDEX idx_battles_player2_id ON battles(player2_id);

-- Index WHERE clause columns
CREATE INDEX idx_battles_status ON battles(status);
CREATE INDEX idx_battles_created_at ON battles(created_at DESC);

-- Composite index for common queries
CREATE INDEX idx_battles_status_created ON battles(status, created_at DESC);

-- Partial index (for specific conditions)
CREATE INDEX idx_active_battles ON battles(id) WHERE status = 'running';

-- Full-text search
CREATE INDEX idx_algorithms_code_fts ON algorithms USING gin(to_tsvector('english', code));
CORE SCHEMA
Users Table:
sql
CREATE TABLE users (
    id SERIAL PRIMARY KEY,
    username VARCHAR(50) UNIQUE NOT NULL,
    email VARCHAR(255) UNIQUE NOT NULL,
    password_hash VARCHAR(255) NOT NULL,
    
    -- Stats
    rating INT DEFAULT 1000,
    battles_won INT DEFAULT 0,
    battles_lost INT DEFAULT 0,
    
    -- Subscription
    subscription_tier VARCHAR(20) DEFAULT 'free',
    subscription_expires_at TIMESTAMP,
    
    -- Timestamps
    created_at TIMESTAMP DEFAULT NOW(),
    updated_at TIMESTAMP DEFAULT NOW(),
    last_login_at TIMESTAMP,
    
    -- Indexes
    CONSTRAINT chk_rating CHECK (rating >= 0),
    CONSTRAINT chk_subscription_tier CHECK (subscription_tier IN ('free', 'premium', 'elite'))
);

-- Indexes
CREATE INDEX idx_users_rating ON users(rating DESC);
CREATE INDEX idx_users_created_at ON users(created_at DESC);
Algorithms Table:
sql
CREATE TABLE algorithms (
    id SERIAL PRIMARY KEY,
    user_id INT NOT NULL REFERENCES users(id) ON DELETE CASCADE,
    
    -- Code
    code TEXT NOT NULL,
    language VARCHAR(20) NOT NULL,
    
    -- Metadata
    name VARCHAR(100),
    description TEXT,
    
    -- Stats
    battles_won INT DEFAULT 0,
    battles_lost INT DEFAULT 0,
    death_count INT DEFAULT 0, -- Permadeath tracker
    is_alive BOOLEAN DEFAULT TRUE,
    
    -- Performance
    avg_execution_time_ms INT,
    avg_memory_usage_mb INT,
    
    -- Evolution
    generation INT DEFAULT 1,
    parent_algorithm_id INT REFERENCES algorithms(id),
    
    -- Traits (JSON array)
    traits JSONB DEFAULT '[]',
    
    -- Timestamps
    created_at TIMESTAMP DEFAULT NOW(),
    updated_at TIMESTAMP DEFAULT NOW(),
    killed_at TIMESTAMP,
    
    CONSTRAINT chk_language CHECK (language IN ('python', 'rust', 'javascript')),
    CONSTRAINT chk_death_count CHECK (death_count <= 3)
);

-- Indexes
CREATE INDEX idx_algorithms_user_id ON algorithms(user_id);
CREATE INDEX idx_algorithms_is_alive ON algorithms(is_alive);
CREATE INDEX idx_algorithms_battles_won ON algorithms(battles_won DESC);
CREATE INDEX idx_algorithms_traits ON algorithms USING gin(traits);
Battles Table:
sql
CREATE TABLE battles (
    id SERIAL PRIMARY KEY,
    
    -- Players
    player1_id INT NOT NULL REFERENCES users(id),
    player2_id INT NOT NULL REFERENCES users(id),
    
    -- Algorithms
    algorithm1_id INT NOT NULL REFERENCES algorithms(id),
    algorithm2_id INT NOT NULL REFERENCES algorithms(id),
    
    -- Problem
    problem_id INT NOT NULL REFERENCES problems(id),
    
    -- Status
    status VARCHAR(20) DEFAULT 'pending',
    
    -- Results
    winner_id INT REFERENCES users(id),
    winner_algorithm_id INT REFERENCES algorithms(id),
    
    -- Performance metrics (JSON)
    algorithm1_metrics JSONB,
    algorithm2_metrics JSONB,
    
    -- Timestamps
    created_at TIMESTAMP DEFAULT NOW(),
    started_at TIMESTAMP,
    completed_at TIMESTAMP,
    
    CONSTRAINT chk_status CHECK (status IN ('pending', 'running', 'completed', 'cancelled')),
    CONSTRAINT chk_different_players CHECK (player1_id != player2_id)
);

-- Indexes
CREATE INDEX idx_battles_player1_id ON battles(player1_id);
CREATE INDEX idx_battles_player2_id ON battles(player2_id);
CREATE INDEX idx_battles_status ON battles(status);
CREATE INDEX idx_battles_created_at ON battles(created_at DESC);
CREATE INDEX idx_battles_winner_id ON battles(winner_id);
Problems Table:
sql
CREATE TABLE problems (
    id SERIAL PRIMARY KEY,
    title VARCHAR(200) NOT NULL,
    description TEXT NOT NULL,
    difficulty VARCHAR(20) NOT NULL,
    
    -- Test cases (JSON array)
    test_cases JSONB NOT NULL,
    
    -- Zone (for Ecosystem Wars)
    zone INT DEFAULT 1,
    
    -- Stats
    total_attempts INT DEFAULT 0,
    success_rate FLOAT DEFAULT 0.0,
    
    created_at TIMESTAMP DEFAULT NOW(),
    
    CONSTRAINT chk_difficulty CHECK (difficulty IN ('easy', 'medium', 'hard', 'expert')),
    CONSTRAINT chk_zone CHECK (zone BETWEEN 1 AND 4)
);

CREATE INDEX idx_problems_difficulty ON problems(difficulty);
CREATE INDEX idx_problems_zone ON problems(zone);
Algorithm Executions (Performance Tracking):
sql
CREATE TABLE algorithm_executions (
    id BIGSERIAL PRIMARY KEY,
    algorithm_id INT NOT NULL REFERENCES algorithms(id) ON DELETE CASCADE,
    battle_id INT REFERENCES battles(id) ON DELETE CASCADE,
    
    -- Performance
    execution_time_ms INT NOT NULL,
    memory_usage_mb INT NOT NULL,
    test_cases_passed INT NOT NULL,
    test_cases_total INT NOT NULL,
    
    -- Output
    stdout TEXT,
    stderr TEXT,
    exit_code INT,
    
    -- Timestamp
    executed_at TIMESTAMP DEFAULT NOW(),
    
    CONSTRAINT chk_execution_time CHECK (execution_time_ms >= 0),
    CONSTRAINT chk_memory_usage CHECK (memory_usage_mb >= 0)
);

-- Indexes
CREATE INDEX idx_executions_algorithm_id ON algorithm_executions(algorithm_id);
CREATE INDEX idx_executions_battle_id ON algorithm_executions(battle_id);
CREATE INDEX idx_executions_executed_at ON algorithm_executions(executed_at DESC);
MIGRATION WORKFLOW (Alembic)
Create Migration:
bash
# Auto-generate migration from model changes
alembic revision --autogenerate -m "add algorithms table"

# Create empty migration for manual changes
alembic revision -m "add indexes for performance"
Migration File Structure:
python
"""add algorithms table

Revision ID: abc123
Revises: def456
Create Date: 2026-02-04 18:00:00

"""
from alembic import op
import sqlalchemy as sa

# Revision identifiers
revision = 'abc123'
down_revision = 'def456'
branch_labels = None
depends_on = None

def upgrade():
    # Create table
    op.create_table(
        'algorithms',
        sa.Column('id', sa.Integer(), primary_key=True),
        sa.Column('user_id', sa.Integer(), nullable=False),
        sa.Column('code', sa.Text(), nullable=False),
        sa.Column('language', sa.String(20), nullable=False),
        sa.Column('created_at', sa.DateTime(), server_default=sa.func.now()),
    )
    
    # Add foreign key
    op.create_foreign_key(
        'fk_algorithms_users',
        'algorithms', 'users',
        ['user_id'], ['id'],
        ondelete='CASCADE'
    )
    
    # Add indexes
    op.create_index('idx_algorithms_user_id', 'algorithms', ['user_id'])
    op.create_index('idx_algorithms_created_at', 'algorithms', ['created_at'])

def downgrade():
    op.drop_index('idx_algorithms_created_at')
    op.drop_index('idx_algorithms_user_id')
    op.drop_constraint('fk_algorithms_users', 'algorithms')
    op.drop_table('algorithms')
Run Migrations:
bash
# Upgrade to latest
alembic upgrade head

# Downgrade one revision
alembic downgrade -1

# Show migration history
alembic history

# Show current version
alembic current
DATA INTEGRITY RULES
Use Constraints:
sql
-- NOT NULL (require value)
email VARCHAR(255) NOT NULL

-- UNIQUE (prevent duplicates)
username VARCHAR(50) UNIQUE

-- CHECK (validate data)
rating INT CHECK (rating >= 0 AND rating <= 5000)

-- FOREIGN KEY (referential integrity)
user_id INT REFERENCES users(id) ON DELETE CASCADE

-- DEFAULT (set default value)
created_at TIMESTAMP DEFAULT NOW()
Soft Deletes vs Hard Deletes:
sql
-- ✅ SOFT DELETE (keep data, mark as deleted)
ALTER TABLE algorithms ADD COLUMN deleted_at TIMESTAMP;

UPDATE algorithms SET deleted_at = NOW() WHERE id = 123;

-- Query only non-deleted
SELECT * FROM algorithms WHERE deleted_at IS NULL;

-- ❌ HARD DELETE (permanent removal)
DELETE FROM algorithms WHERE id = 123;
QUERY OPTIMIZATION
Use EXPLAIN ANALYZE:
sql
-- Check query performance
EXPLAIN ANALYZE
SELECT u.username, COUNT(b.id) as battle_count
FROM users u
LEFT JOIN battles b ON u.id = b.player1_id
WHERE u.rating > 1500
GROUP BY u.id
ORDER BY battle_count DESC
LIMIT 10;

-- Look for:
-- - Seq Scan (BAD - needs index)
-- - Index Scan (GOOD)
-- - Execution time < 50ms (GOAL)
Avoid N+1 Queries:
sql
-- ❌ BAD (N+1 queries in application code)
SELECT * FROM battles;
-- Then for each battle:
SELECT * FROM users WHERE id = battle.player1_id;

-- ✅ GOOD (single query with JOIN)
SELECT b.*, u1.username as player1_name, u2.username as player2_name
FROM battles b
JOIN users u1 ON b.player1_id = u1.id
JOIN users u2 ON b.player2_id = u2.id;
JSONB OPERATIONS (For traits, metrics)
Query JSONB:
sql
-- Check if key exists
SELECT * FROM algorithms WHERE traits ? 'Cache Warrior';

-- Get array length
SELECT id, jsonb_array_length(traits) as trait_count
FROM algorithms;

-- Extract value
SELECT id, traits->0 as first_trait FROM algorithms;

-- Filter by JSON property
SELECT * FROM battles 
WHERE algorithm1_metrics->>'execution_time_ms' < '100';
Index JSONB:
sql
-- GIN index for JSONB (enables ? operator)
CREATE INDEX idx_algorithms_traits ON algorithms USING gin(traits);
BACKUP & RESTORE
Daily Backups:
bash
# Backup database
pg_dump -U postgres -d algorithm_arena -F c -f backup_$(date +%Y%m%d).dump

# Restore database
pg_restore -U postgres -d algorithm_arena -c backup_20260204.dump
Point-in-Time Recovery:
sql
-- Enable WAL archiving in postgresql.conf
wal_level = replica
archive_mode = on
archive_command = 'cp %p /archive/%f'
MONITORING
Essential Queries:
sql
-- Slow queries (> 1 second)
SELECT query, mean_exec_time, calls
FROM pg_stat_statements
WHERE mean_exec_time > 1000
ORDER BY mean_exec_time DESC;

-- Table sizes
SELECT 
    schemaname,
    tablename,
    pg_size_pretty(pg_total_relation_size(schemaname||'.'||tablename)) AS size
FROM pg_tables
WHERE schemaname = 'public'
ORDER BY pg_total_relation_size(schemaname||'.'||tablename) DESC;

-- Index usage
SELECT 
    schemaname,
    tablename,
    indexname,
    idx_scan,
    idx_tup_read
FROM pg_stat_user_indexes
WHERE idx_scan = 0  -- Unused indexes
ORDER BY pg_relation_size(indexrelid) DESC;
