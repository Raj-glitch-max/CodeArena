Memoization:
typescript
import { memo, useMemo, useCallback } from 'react';

// Prevent re-renders if props unchanged
export const BattleCard = memo(({ battle }: BattleCardProps) => {
  // Expensive calculation
  const stats = useMemo(() => {
    return calculateBattleStats(battle);
  }, [battle.id]);
  
  // Stable function reference
  const handleClick = useCallback(() => {
    console.log('Battle clicked:', battle.id);
  }, [battle.id]);
  
  return <div onClick={handleClick}>{stats.winRate}%</div>;
});
