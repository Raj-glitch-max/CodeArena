from sqlalchemy import Column, Integer, String, DateTime, ForeignKey
from sqlalchemy.orm import relationship
from datetime import datetime

class Battle(Base):
    __tablename__ = "battles"
    
    # Primary Key
    id = Column(Integer, primary_key=True, index=True)
    
    # Foreign Keys (ALWAYS indexed)
    player1_id = Column(Integer, ForeignKey("users.id"), index=True, nullable=False)
    player2_id = Column(Integer, ForeignKey("users.id"), index=True, nullable=False)
    
    # Status (indexed for queries)
    status = Column(String(20), index=True, default="pending")
    
    # Timestamps (ALWAYS included)
    created_at = Column(DateTime, default=datetime.utcnow, index=True)
    updated_at = Column(DateTime, default=datetime.utcnow, onupdate=datetime.utcnow)
    
    # Relationships
    player1 = relationship("User", foreign_keys=[player1_id])
    player2 = relationship("User", foreign_keys=[player2_id])
