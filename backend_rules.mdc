from redis import asyncio as aioredis
import json

redis = aioredis.from_url("redis://localhost")

async def get_leaderboard():
    # Try cache first
    cached = await redis.get("leaderboard")
    if cached:
        return json.loads(cached)
    
    # Cache miss - query database
    leaderboard = await query_leaderboard()
    
    # Cache for 5 minutes
    await redis.setex("leaderboard", 300, json.dumps(leaderboard))
    
    return leaderboard
WEBSOCKET RULES
Real-Time Battle Updates:
python
from fastapi import WebSocket

@router.websocket("/ws/battles/{battle_id}")
async def battle_websocket(websocket: WebSocket, battle_id: int):
    await websocket.accept()
    
    try:
        # Subscribe to battle events
        pubsub = redis.pubsub()
        await pubsub.subscribe(f"battle:{battle_id}")
        
        async for message in pubsub.listen():
            if message["type"] == "message":
                await websocket.send_json(json.loads(message["data"]))
                
    except WebSocketDisconnect:
        await pubsub.unsubscribe(f"battle:{battle_id}")
