Store Structure:
typescript
import { create } from 'zustand';

interface BattleState {
  // State
  battles: Battle[];
  currentBattle: Battle | null;
  loading: boolean;
  
  // Actions
  fetchBattles: () => Promise<void>;
  selectBattle: (id: string) => void;
  clearBattle: () => void;
}

export const useBattleStore = create<BattleState>((set, get) => ({
  // Initial state
  battles: [],
  currentBattle: null,
  loading: false,
  
  // Actions
  fetchBattles: async () => {
    set({ loading: true });
    try {
      const battles = await api.getBattles();
      set({ battles, loading: false });
    } catch (error) {
      set({ loading: false });
      throw error;
    }
  },
  
  selectBattle: (id) => {
    const battle = get().battles.find(b => b.id === id);
    set({ currentBattle: battle });
  },
  
  clearBattle: () => set({ currentBattle: null }),
}));
